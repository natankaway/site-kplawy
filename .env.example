# Smart download link (/download) — public store config. Override per environment.
# All values are public (store URLs/IDs are not secrets); they live here only so
# they can change without code edits. The route works with these left at defaults.

# iOS App Store listing.
# Default (when unset): https://apps.apple.com/app/id6761232468 (country-neutral).
APP_STORE_URL=https://apps.apple.com/app/id6761232468

# Google Play listing.
# LEAVE EMPTY until the Android app is published — an empty value makes the route
# send Android visitors to the web download page instead of a dead Play listing.
# When live, set: https://play.google.com/store/apps/details?id=com.kplawy.instantreplay
ANDROID_STORE_URL=

# Optional override for the desktop / iPad / unknown fallback target.
# Empty (default) => the route uses a locale-aware /<locale>/download path.
SMART_DOWNLOAD_DESKTOP_FALLBACK=
